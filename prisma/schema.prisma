
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  callsign  String?  @unique
  phone     String?

  role      String   @default("MEMBER")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
